{
  "name": "chzzk-plus-web-extension",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "node scripts/build.mjs",
    "dev": "node scripts/build.mjs --watch --mode=development",
    "check": "tsc --noEmit && eslint src tests scripts",
    "test": "vitest run",
    "verify": "npm run check && npm test && npm run build",
    "safari": "npm run build && xcodebuild -project ../chzzk-plus.xcodeproj -scheme 'chzzk-plus (macOS)' -configuration Debug build"
  },
  "devDependencies": {
    "@eslint/js": "10.0.1",
    "@types/firefox-webext-browser": "143.0.0",
    "esbuild": "0.28.1",
    "eslint": "10.7.0",
    "typescript": "6.0.3",
    "typescript-eslint": "8.64.0",
    "vitest": "4.1.10"
  }
}
