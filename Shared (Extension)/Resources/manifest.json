{
  "manifest_version": 3,
  "name": "CHZZK Plus",
  "description": "Safari에서 치지직 플레이어와 채팅을 개선합니다.",
  "version": "0.1.0",
  "icons": {
    "16": "images/icon-16.png",
    "32": "images/icon-32.png",
    "48": "images/icon-48.png",
    "64": "images/icon-64.png",
    "96": "images/icon-96.png",
    "128": "images/icon-128.png",
    "256": "images/icon-256.png",
    "512": "images/icon-512.png"
  },
  "background": {
    "scripts": ["background.js"],
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": ["*://chzzk.naver.com/*"],
      "js": [
        "core/runtime.js",
        "core/dom-bus.js",
        "modules/sharpness.js",
        "modules/playback-bar.js",
        "modules/stream-stats.js",
        "modules/screenshot.js",
        "modules/ad-ui.js",
        "modules/chat-style.js",
        "content.js"
      ],
      "css": ["content.css"],
      "run_at": "document_start",
      "all_frames": false
    }
  ],
  "web_accessible_resources": [
    {
      "matches": ["*://chzzk.naver.com/*"],
      "resources": ["page/network.js", "page/blinded.js", "page/player.js"]
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": "images/toolbar-icon.svg"
  },
  "permissions": ["storage", "tabs", "activeTab"],
  "host_permissions": [
    "*://chzzk.naver.com/*",
    "https://api.chzzk.naver.com/*",
    "https://*.pstatic.net/*",
    "https://veta.naver.com/*"
  ]
}
